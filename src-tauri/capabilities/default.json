{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$TEMP/*" }]
    },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://localhost:11434/**" },
        { "url": "http://127.0.0.1:11434/**" },
        { "url": "https://ollama.com/**" }
      ]
    }
  ]
}
